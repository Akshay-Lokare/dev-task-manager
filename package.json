{
  "name": "meowlogger",
  "version": "2.1.0",
  "description": "MeowLogger: a desktop dev task tracker built with Electron, React, and Vite",
  "main": "electron/main.js",
  "scripts": {
    "icons": "node scripts/generate-icon.mjs",
    "postinstall": "npm run icons",
    "dev": "node scripts/dev.mjs",
    "build": "npm run icons && vite build && electron-builder",
    "preview": "electron ."
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "electron-store": "^8.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "rcedit": "^4.0.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.2",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.dev.tasktracker",
    "productName": "MeowLogger",
    "directories": {
      "buildResources": "build",
      "output": "github-release"
    },
    "icon": "build/icon.ico",
    "afterPack": "scripts/electron-after-pack.cjs",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.png",
      "build/icon-256.png",
      "build/icon.ico"
    ]
  }
}
